# ============================================================
# Auto-Co Configuration
# ============================================================
# Copy to .env:  cp .env.example .env
# Most users only need the first 2 lines.
# ============================================================

# --- Required ---
ANTHROPIC_API_KEY=              # Your Anthropic API key (skip if using Claude Code's built-in auth)
MODEL=opus                      # opus (~$1.80/cycle) or sonnet (~$0.50/cycle)

# --- Optional: Telegram Notifications ---
# Get escalation requests on your phone. Skip if you just want to check consensus.md manually.
# TELEGRAM_BOT_TOKEN=           # From @BotFather on Telegram
# TELEGRAM_CHAT_ID=             # Your chat ID (message @userinfobot to get it)

# ============================================================
# Advanced (defaults work fine — change only if you need to)
# ============================================================

# Loop timing
# LOOP_INTERVAL=120             # Seconds between cycles (default: 120)
# CYCLE_TIMEOUT_SECONDS=1800    # Max seconds per cycle (default: 1800 = 30 min)
# IDLE_INTERVAL=600             # Sleep when idle (default: 600 = 10 min, 0 = disable)

# Error handling
# MAX_CONSECUTIVE_ERRORS=3      # Errors before circuit breaker trips
# COOLDOWN_SECONDS=300          # Cooldown after circuit breaker (default: 5 min)
# LIMIT_WAIT_SECONDS=3600       # Wait on rate limit (default: 1 hour)
# MAX_CYCLES=0                  # Stop after N cycles (0 = unlimited)

# Retry backoff
# RETRY_BASE_SECONDS=30         # Initial retry delay
# RETRY_MAX_SECONDS=600         # Max retry delay

# Memory & state
# QMD_ENABLED=true              # QMD semantic search (default: true)
# STATE_DIR=state               # Structured state directory
# SUMMARY_ENABLED=true          # Cycle summaries in logs/summaries/
# MAX_LOGS=200                  # Max cycle log files to keep

# Webhooks
# NOTIFY_URL=                   # POST JSON after each cycle
# WEBHOOK_URL=                  # POST JSON on lifecycle events

# Plugins
# PLUGIN_DIR=                   # Directory with pre-cycle.sh / post-cycle.sh hooks
# PARALLEL_DIR=                 # Directory with .md prompts for parallel sessions

# Service tokens (optional — skip if already logged in via CLI)
# VERCEL_TOKEN=
# RAILWAY_TOKEN=
# SUPABASE_ACCESS_TOKEN=
# GITHUB_TOKEN=
